import asyncio
import threading
import time
import traceback
from typing import Dict, List, Optional
from datetime import datetime, timedelta
from pathlib import Path

from src.core.logger import BotLogger
from src.core.market.data_fetcher import DataFetcher
from src.core.trading.order_manager import OrderManager
from src.core.trading.position import Position
from src.config.constants import OrderSide, ExitReason
from src.core.risk.risk_manager import RiskManager
from src.core.risk.risk_controller import RiskController
from src.intelligence.strategy_engine import StrategyEngine
from src.intelligence.genetic.genetic_optimizer import GeneticOptimizer
from src.notifications.telegram_notifier import TelegramNotifier
from src.notifications.discord_notifier import DiscordNotifier
from src.utils.api_client import AsyncBingXClient, BingXClient
from src.utils.performance_metrics import PerformanceMetrics
from src.utils.sqlite_history import AsyncSQLiteTradeHistory, SQLiteTradeHistory
from src.utils.profiler import Profiler
from src.core.scanner.market_scanner import MarketScanner
from src.core.executor.trade_executor import TradeExecutor
from src.core.exit.exit_manager import ExitManager
from src.config.settings import Settings

class TradingEngine:
    def __init__(self, settings: Settings):
        self.settings = settings
        self.logger = BotLogger(level=settings.get("log_level", "INFO"))
        self._running = False
        self._stop_event = asyncio.Event()
        self._client: Optional[AsyncBingXClient] = None
        self._loop = None  # для сохранения event loop

        self.profiler = Profiler(self.logger, settings.data)
        self.data_fetcher = None
        self.risk_manager = None
        self.order_manager = None
        self.risk_controller = RiskController(self.logger, settings.data)
        self.strategy_engine = StrategyEngine(self.logger, settings)
        self.performance_metrics = PerformanceMetrics(self.logger, settings.data)
        self.sqlite_history = AsyncSQLiteTradeHistory()

        self.scanner = None
        self.executor = None
        self.exit_manager = None

        self.telegram = None
        self.discord = None

        self.balance = settings.get("virtual_balance", 100.0)
        self.real_balance = 0.0
        self.open_positions: Dict[str, Position] = {}
        self.last_prices: Dict[str, float] = {}
        self.start_time = time.time()

        self._heartbeat_file = Path("data/heartbeat.txt")
        self._heartbeat_file.parent.mkdir(parents=True, exist_ok=True)

        self.scan_interval = settings.get("scan_interval_minutes", 2) * 60
        self.last_scan_time = 0.0
        self.force_scan = False

        self.max_positions = self._calc_max_positions()
        self.logger.info(f"🎯 Лимит позиций: {self.max_positions}")

        self.daily_profit_target = settings.get("daily_profit_target_percent", 5.0)
        self.daily_target_reached = False

        self.genetic_optimizer = GeneticOptimizer(self.logger, settings.data)
        self._last_opt_time = 0
        self.consecutive_losses = 0
        self.auto_optimization_interval = 14400
        self._last_optimization_time = 0
        self._performance_history = []
        self._best_balance = 0.0
        self.initial_balance = self.balance
        self.critical_drawdown_limit = 0.30

        from src.utils.auto_recovery import SelfHealingWatchdog, ProxyListUpdater
        self.watchdog = SelfHealingWatchdog(self.logger, restart_callback=self._restart_callback)
        self.proxy_updater = ProxyListUpdater(self.logger)
        # Watchdog отложен для стабильности
        # self.watchdog.start()
        self.logger.info("🛡️ Watchdog создан, но запуск отложен")

    async def _init_client(self):
        if self._client is None:
            self._client = AsyncBingXClient(
                api_key=self.settings.get("api_key"),
                api_secret=self.settings.get("api_secret"),
                demo_mode=self.settings.get("demo_mode", True),
                settings=self.settings.data
            )
            await self._client._sync_server_time()
            self.logger.info("Асинхронный API клиент инициализирован")

    @property
    def client(self) -> AsyncBingXClient:
        if self._client is None:
            raise RuntimeError("Client not initialized. Call _init_client() first.")
        return self._client

    @client.setter
    def client(self, value):
        self._client = value

    def _calc_max_positions(self) -> int:
        base_max = self.settings.get("max_positions", 2)
        if self.balance < 30:
            return 1
        elif self.balance < 60:
            return min(2, base_max)
        return base_max

    @property
    def running(self) -> bool:
        return self._running

    async def start_async(self):
        await self._init_client()
        self.data_fetcher = DataFetcher(self.client, self.logger, self.settings.data)
        self.risk_manager = RiskManager(self.client, self.settings.data)
        self.order_manager = OrderManager(
            self.client, self.logger, self.risk_manager,
            demo_mode=self.settings.get("demo_mode", True)
        )
        self.scanner = MarketScanner(
            self.settings, self.logger, self.data_fetcher,
            self.risk_controller, self.strategy_engine
        )
        self.executor = TradeExecutor(
            self.settings, self.logger, self.order_manager,
            self.risk_manager, self.risk_controller
        )
        self.exit_manager = ExitManager(
            self.settings, self.logger, self.data_fetcher,
            self.risk_manager, self.risk_controller,
            self.strategy_engine, self.order_manager,
            sqlite_history=self.sqlite_history
        )

        if self.settings.get("telegram_enabled"):
            self.telegram = TelegramNotifier(
                bot_token=self.settings.get("telegram_bot_token"),
                chat_id=self.settings.get("telegram_chat_id"),
                logger=self.logger,
                commands_enabled=self.settings.get("telegram_commands_enabled", True)
            )
            self.telegram.set_engine(self)

        if self.settings.get("discord_enabled"):
            self.discord = DiscordNotifier(
                webhook_url=self.settings.get("discord_webhook_url"),
                logger=self.logger
            )

        await self._update_real_balance_async()
        self.risk_controller.daily_start_balance = self.balance
        self.performance_metrics.daily_start_balance = self.balance
        self.initial_balance = self.balance

        self._running = True
        self._stop_event.clear()
        self.logger.info("Асинхронный движок запущен")
        self._loop = asyncio.get_running_loop()
        asyncio.create_task(self._async_main())

    def start(self):
        loop = asyncio.get_event_loop()
        if loop.is_running():
            asyncio.create_task(self.start_async())
        else:
            loop.run_until_complete(self.start_async())

    async def stop_async(self):
        self._running = False
        self._stop_event.set()
        if self.sqlite_history:
            try:
                await self.sqlite_history.close()
            except Exception as e:
                self.logger.warning(f"Ошибка при закрытии БД: {e}")
        if self._client:
            try:
                await self._client.close()
            except Exception as e:
                self.logger.warning(f"Ошибка при закрытии клиента API: {e}")
        self.logger.info("Торговый движок остановлен")

    def stop(self):
        if self._running:
            loop = getattr(self, '_loop', None)
            if loop is None:
                try:
                    loop = asyncio.get_event_loop()
                except RuntimeError:
                    loop = asyncio.new_event_loop()
                    asyncio.set_event_loop(loop)
            if loop.is_running():
                asyncio.run_coroutine_threadsafe(self.stop_async(), loop)
            else:
                loop.run_until_complete(self.stop_async())

    def scan_now(self):
        self.force_scan = True
        self.logger.info("🔍 Запрошено ручное сканирование...")

    async def _async_main(self):
        while self._running:
            try:
                self._heartbeat_file.write_text(str(time.time()))
            except:
                pass
            try:
                await asyncio.wait_for(self._run_iteration_async(), timeout=600.0)
            except asyncio.TimeoutError:
                self.logger.error("Итерация превысила таймаут 600 секунд")
            except Exception as e:
                self.logger.error(f"Ошибка в цикле: {e}\n{traceback.format_exc()}")
                await asyncio.sleep(30)

    async def _run_iteration_async(self):
        self.profiler.record_system_metrics()
        await self._sync_positions_with_exchange_async()
        await self._update_positions_prices_async()

        # Используем синхронный метод через поток (временно)
        import asyncio
        await asyncio.to_thread(
            self.exit_manager.check_all_positions,
            self.open_positions,
            get_ticker_func=self._sync_get_ticker,
            update_balance_func=self._update_virtual_balance_sync,
            save_history=True,
            telegram_notifier=self.telegram,
            discord_notifier=self.discord,
            current_balance=self.balance
        )

        if self.settings.get("stop_on_daily_target"):
            daily_pnl_pct = self.performance_metrics.get_daily_pnl_percent()
            if daily_pnl_pct >= self.daily_profit_target and not self.daily_target_reached:
                self.daily_target_reached = True
                self.logger.info(f"Daily target {self.daily_profit_target}% reached. Trading stopped.")
                self._running = False
                if self.telegram:
                    self.telegram.send_sync(f"Daily target +{daily_pnl_pct:.2f}% reached! Bot stopped.")
                return

        if self.balance > 0 and self.performance_metrics.daily_start_balance:
            drawdown = (self.balance - self.performance_metrics.daily_start_balance) / self.performance_metrics.daily_start_balance * 100
            if drawdown <= -20:
                self.logger.critical(f"EMERGENCY STOP! Drawdown {drawdown:.1f}%")
                await self.emergency_close_all_async()
                self._running = False
                return

        new_max = self._calc_max_positions()
        if new_max != self.max_positions:
            self.logger.info(f"Position limit changed: {self.max_positions} -> {new_max}")
        self.max_positions = new_max

        now = time.time()
        if not self.force_scan and (now - self.last_scan_time < self.scan_interval):
            return
        self.force_scan = False
        self.last_scan_time = now

        can_scan, reason = self.risk_controller.check_circuit_breaker(self.balance)
        if not can_scan:
            self.logger.warning(f"Scan skipped: {reason}")
            return

        account = await self.client.get_account_info()
        available_balance = account['available'] if account else self.balance
        min_required = self.risk_manager.get_min_entry_requirement(self.balance)
        if available_balance < min_required:
            self.logger.warning(f"Insufficient funds: {available_balance:.2f} USDT (need {min_required:.2f})")
            return

        if len(self.open_positions) >= self.max_positions:
            return

        ignore_session = self.settings.get("force_ignore_session", False)
        self.logger.info("Starting market scan...")
        candidates = await self.scanner.scan_async(
            self.balance, max_pairs=150, max_asset_price_ratio=0.5,
            ignore_session_check=ignore_session
        )
        self.logger.info(f"Processing candidates: {len(candidates)}")

        for c in candidates:
            symbol = c['symbol']
            if len(self.open_positions) >= self.max_positions:
                break
            if self.settings.get("correlation_limit_enabled") and not self.risk_controller.can_open_in_category(symbol):
                continue
            can_trade, reason = self.risk_manager.anti_chase.can_trade()
            if not can_trade:
                continue
            self.logger.info(f"Attempting entry for {symbol}")
            pos = await self.executor.execute_trade_async(
                c, self.balance, self.open_positions,
                self.settings.get("trailing_stop_enabled", True),
                self.settings.get("trailing_stop_distance_percent", 1.5),
                self.telegram,
                self.performance_metrics.get_daily_pnl_percent(),
                self.performance_metrics.get_weekly_pnl_percent(),
                self.performance_metrics.weekly_start_balance
            )
            if pos:
                self.open_positions[pos.symbol] = pos
                self.risk_controller.register_position_open(pos.symbol)
                self.strategy_engine.last_trade_time = time.time()
                self.performance_metrics.record_trade(pos.symbol, pos.entry_price, pos.side.value,
                                                     strategy=c['indicators'].get('entry_type', 'unknown'))
                if self.discord:
                    self.discord.send_trade_open(pos.symbol, pos.side.value, pos.entry_price)

    async def _sync_positions_with_exchange_async(self):
        exchange_positions = await self.client.get_positions()
        exchange_symbols = set()
        exchange_dict = {}
        for p in exchange_positions:
            symbol = p['symbol']
            exchange_symbols.add(symbol)
            exchange_dict[symbol] = p

        for sym in list(self.open_positions.keys()):
            if sym not in exchange_symbols:
                pos = self.open_positions[sym]
                ticker = await self.client.get_ticker(sym)
                exit_price = ticker.get('lastPrice', pos.entry_price)
                pnl = pos.calculate_unrealized_pnl_at_price(exit_price)
                self.logger.info(f"🏁 Позиция {sym} закрыта на бирже | PnL: {pnl:+.2f}")
                await self.exit_manager.record_exchange_tp_close_async(sym, pos, exit_price, pnl)
                del self.open_positions[sym]
                self.risk_controller.register_position_close(sym)

        for sym, p in exchange_dict.items():
            amt = float(p.get('positionAmt', 0))
            entry_price = float(p.get('avgPrice', 0))
            if entry_price <= 0:
                ticker = await self.client.get_ticker(sym)
                entry_price = ticker.get('lastPrice', 0)
            side = OrderSide.BUY if p.get('positionSide', 'LONG') == 'LONG' else OrderSide.SELL
            qty = abs(amt)
            if sym in self.open_positions:
                pos = self.open_positions[sym]
                pos.quantity = qty
                pos.entry_price = entry_price
                pos.current_price = entry_price
            else:
                pos = Position(
                    symbol=sym, side=side, quantity=qty, entry_price=entry_price,
                    leverage=int(p.get('leverage', 1)), stop_loss_price=0.0, take_profit_price=0.0
                )
                self.open_positions[sym] = pos
                self.risk_controller.register_position_open(sym)
                self.logger.info(f"✅ Синхронизирована позиция {sym} ({side.value} {qty} @ {entry_price:.4f})")

        await self._update_real_balance_async()

    async def _update_real_balance_async(self):
        if self.settings.get("demo_mode"):
            return
        account = await self.client.get_account_info()
        if account:
            self.real_balance = account['balance']
            self.balance = self.real_balance

    async def _update_positions_prices_async(self):
        tasks = [self._fetch_price(sym, pos) for sym, pos in self.open_positions.items()]
        await asyncio.gather(*tasks, return_exceptions=True)

    async def _fetch_price(self, symbol: str, pos: Position):
        ticker = await self.client.get_ticker(symbol)
        price = ticker.get('lastPrice', pos.entry_price)
        self.last_prices[symbol] = price
        pos.update_market_price(price)

    def _sync_get_ticker(self, symbol: str) -> Dict:
        # Используем асинхронный клиент через синхронный вызов
        import asyncio
        try:
            loop = asyncio.get_event_loop()
        except RuntimeError:
            loop = asyncio.new_event_loop()
            asyncio.set_event_loop(loop)
        if loop.is_running():
            import concurrent.futures
            with concurrent.futures.ThreadPoolExecutor() as executor:
                future = executor.submit(asyncio.run, self.client.get_ticker(symbol))
                return future.result()
        else:
            return loop.run_until_complete(self.client.get_ticker(symbol))

    def _update_virtual_balance_sync(self, pnl: float, strategy_type: str = None):
        if self.settings.get("demo_mode"):
            self.balance += pnl
            self.settings.set("virtual_balance", self.balance)
        self.risk_controller.add_pnl(pnl)
        self.risk_manager.update_pnl(pnl)
        self.strategy_engine.record_trade_result(pnl)
        self.performance_metrics.record_close(pnl, self.balance, strategy_type)

    async def emergency_close_all_async(self) -> float:
        total_pnl = 0.0
        for sym in list(self.open_positions.keys()):
            pos = self.open_positions[sym]
            ticker = await self.client.get_ticker(sym)
            exit_price = ticker.get('lastPrice', pos.entry_price)
            success = await self.client.close_position_with_cleanup(sym, "LONG" if pos.side == OrderSide.BUY else "SHORT")
            if success:
                pnl = pos.calculate_unrealized_pnl_at_price(exit_price)
                total_pnl += pnl
                await self.exit_manager._save_trade_to_history_async(sym, pos, exit_price, pnl, ExitReason.MANUAL)
                del self.open_positions[sym]
                self.risk_controller.register_position_close(sym)
        return total_pnl

    def emergency_close_all(self) -> float:
        return asyncio.run(self.emergency_close_all_async())

    def close_position(self, symbol: str) -> bool:
        if symbol in self.open_positions:
            pos = self.open_positions[symbol]
            success = asyncio.run(self.order_manager.close_position(symbol))
            if success:
                del self.open_positions[symbol]
                self.risk_controller.register_position_close(symbol)
            return success
        return False

    def _restart_callback(self):
        self.logger.warning("Выполняется перезапуск движка...")
        self.stop()
        time.sleep(2)
        self.start()
