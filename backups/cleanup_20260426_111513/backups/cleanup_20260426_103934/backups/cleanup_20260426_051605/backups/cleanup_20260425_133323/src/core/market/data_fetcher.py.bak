"""
Data Fetcher v2.0 — загрузка рыночных данных.
Содержит синхронные методы для избежания конфликтов asyncio.
"""
import pandas as pd
import numpy as np
from typing import Dict, List, Optional, Any
import ccxt

from src.core.logger import BotLogger
from src.utils.api_client import AsyncBingXClient
from src.core.market.indicators import calculate_indicators  # <-- ИСПРАВЛЕНО


class DataFetcher:
    def __init__(self, client: AsyncBingXClient, logger: BotLogger, settings: Dict):
        self.client = client
        self.logger = logger
        self.settings = settings
        self.sync_client = client._sync  # синхронный клиент для прямых вызовов

    def get_klines(self, symbol: str, interval: str = "1h", limit: int = 100) -> Optional[pd.DataFrame]:
        """Синхронное получение свечей (основной метод)."""
        try:
            klines = self.sync_client.get_klines(symbol, interval, limit)
            if not klines:
                return None
            df = pd.DataFrame(klines, columns=['timestamp', 'open', 'high', 'low', 'close', 'volume'])
            df['timestamp'] = pd.to_datetime(df['timestamp'], unit='ms')
            return df
        except Exception as e:
            self.logger.error(f"Ошибка загрузки свечей {symbol} {interval}: {e}")
            return None

    def get_multi_timeframe_data(self, symbol: str) -> Dict[str, Optional[pd.DataFrame]]:
        """Загружает данные для нескольких таймфреймов (1h, 4h, 1d)."""
        result = {}
        for tf in ["1h", "4h", "1d"]:
            df = self.get_klines(symbol, tf, limit=100)
            result[tf] = df
        return result

    def calculate_indicators(self, df: pd.DataFrame) -> Dict[str, Any]:
        """Рассчитывает технические индикаторы для DataFrame."""
        if df is None or len(df) < 50:
            return {}
        return calculate_indicators(df)  # <-- ИСПРАВЛЕНО

    def get_all_usdt_contracts(self) -> List[Dict[str, Any]]:
        """Возвращает список всех USDT фьючерсов с биржи."""
        try:
            markets = self.sync_client.exchange.load_markets()
            contracts = []
            for symbol, market in markets.items():
                if (market.get('swap') and market.get('quote') == 'USDT' 
                        and market.get('active') and symbol.endswith(':USDT')):
                    clean_symbol = symbol.replace(':USDT', '')
                    contracts.append({
                        "symbol": clean_symbol,
                        "minQty": market['limits']['amount']['min'] or 0.001,
                        "pricePrecision": market['precision']['price'],
                        "quantityPrecision": market['precision']['amount'],
                    })
            return contracts
        except Exception as e:
            self.logger.error(f"Ошибка получения контрактов: {e}")
            return []

    def get_ticker(self, symbol: str) -> Dict:
        """Получение тикера (синхронно)."""
        return self.sync_client.get_ticker(symbol)

    def get_order_book(self, symbol: str, limit: int = 5) -> Dict:
        return self.sync_client.get_order_book(symbol, limit)

    def get_funding_rate(self, symbol: str) -> Dict:
        return self.sync_client.get_funding_rate(symbol)
