import asyncio
import aiohttp
import time
from typing import Dict, List, Optional

from src.core.logger import BotLogger
from src.core.market.data_fetcher import DataFetcher
from src.core.risk.risk_controller import RiskController
from src.intelligence.strategy_engine import StrategyEngine
from src.core.market.trap_detector import TrapDetector
from src.config.constants import TimeFrame, SignalDirection
from src.config.settings import Settings

class MarketScanner:
    def __init__(self, settings: Settings, logger: BotLogger, data_fetcher: DataFetcher,
                 risk_controller: RiskController, strategy_engine: StrategyEngine):
        self.settings = settings
        self.logger = logger
        self.data_fetcher = data_fetcher
        self.risk_controller = risk_controller
        self.strategy_engine = strategy_engine

        self.trap_detector = TrapDetector(logger, settings.data)
        self.async_concurrency = min(settings.get("async_concurrency", 10), 10)
        self.use_multi_timeframe = settings.get("use_multi_timeframe", True)
        self.multi_tf_list = ["4h", "1d"]
        self.empty_scans_count = 0

        self.current_min_atr = settings.get("min_atr_percent", 2.0)
        self.current_min_adx = settings.get("min_adx", 20)
        self.current_min_volume = settings.get("min_volume_24h_usdt", 100000)

        self.ml_predictor = None
        self.min_trades_for_ml = 50
        self._init_ml_predictor()

        self.signal_quality_threshold = 0.6
        self.last_scan_results = []

    def _init_ml_predictor(self):
        try:
            from src.ml.predictor import MLPredictor
            self.ml_predictor = MLPredictor(self.logger)
            if self.ml_predictor.trainer.is_trained:
                self.logger.info("ML predictor activated")
            else:
                self.logger.info(f"ML predictor waiting for data ({self.min_trades_for_ml} trades)")
        except Exception as e:
            self.logger.debug(f"ML not available: {e}")
            self.ml_predictor = None

    async def scan_async(self, balance: float, max_pairs: int = 150,
                         max_asset_price_ratio: float = 0.5,
                         ignore_session_check: bool = False) -> List[Dict]:
        contracts = await self.data_fetcher.get_all_usdt_contracts()
        if not contracts:
            self.logger.warning("No contracts available for scanning")
            return []

        filtered = []
        symbol_volumes = {}
        stats = {"volume_fail": 0, "price_fail": 0, "spread_fail": 0, "funding_fail": 0, "passed": 0}

        async def check_symbol(symbol):
            await asyncio.sleep(0.05)  # задержка для снижения нагрузки на API
            snapshot = await self.data_fetcher.get_market_snapshot(symbol)
            volume = snapshot.get("volume24h", 0)
            price = snapshot.get("lastPrice", 0)
            if volume < self.current_min_volume:
                stats["volume_fail"] += 1
                return None
            if not self.settings.get("ignore_price_range", False):
                if price <= 0 or price > balance * max_asset_price_ratio:
                    stats["price_fail"] += 1
                    return None
            if self.settings.get("use_spread_filter", True):
                spread = await self.data_fetcher.get_spread_percent(symbol)
                if spread is None or spread > self.settings.get("max_spread_percent", 0.3):
                    stats["spread_fail"] += 1
                    return None
            funding_data = await self.data_fetcher.client.get_funding_rate(symbol)
            funding = funding_data.get("fundingRate", 0)
            max_funding = self.settings.get("max_funding_rate", 0.001)
            if funding > max_funding:
                stats["funding_fail"] += 1
                return None
            stats["passed"] += 1
            return symbol, volume

        tasks = [check_symbol(c['symbol']) for c in contracts if c['symbol'].endswith('/USDT')]
        results = await asyncio.gather(*tasks, return_exceptions=True)
        for res in results:
            if isinstance(res, tuple):
                symbol, vol = res
                filtered.append(symbol)
                symbol_volumes[symbol] = vol

        self.logger.info(f"Filter stats: total={len(contracts)}, volume_fail={stats['volume_fail']}, price_fail={stats['price_fail']}, spread_fail={stats['spread_fail']}, funding_fail={stats['funding_fail']}, passed={stats['passed']}")

        if not filtered:
            self.empty_scans_count += 1
            self.logger.info(f"No scan results (consecutive: {self.empty_scans_count})")
            return []

        self.empty_scans_count = 0
        candidates = []
        semaphore = asyncio.Semaphore(self.async_concurrency)
        reject_stats = {"atr": 0, "adx": 0, "neutral": 0, "weak_signal": 0, "ml": 0, "trap": 0, "no_data": 0}

        async def process_symbol(symbol: str):
            await asyncio.sleep(0.05)  # задержка перед загрузкой свечей
            async with semaphore:
                try:
                    # Получаем свежую сессию для каждого символа
                    session = await self.data_fetcher.client._get_session()
                    try:
                        df = await self.data_fetcher.fetch_klines_async(session, symbol, TimeFrame.H1.value, 100)
                    except (aiohttp.ClientConnectorError, aiohttp.ServerDisconnectedError) as e:
                        # При сетевой ошибке пересоздаём сессию и пробуем ещё раз
                        self.logger.debug(f"Сетевая ошибка {symbol}, пересоздаём сессию: {e}")
                        await self.data_fetcher.client.close()
                        session = await self.data_fetcher.client._get_session()
                        df = await self.data_fetcher.fetch_klines_async(session, symbol, TimeFrame.H1.value, 100)
                    except aiohttp.ClientOSError as e:
                        self.logger.debug(f"OS ошибка {symbol}: {e}")
                        await self.data_fetcher.client.close()
                        session = await self.data_fetcher.client._get_session()
                        df = await self.data_fetcher.fetch_klines_async(session, symbol, TimeFrame.H1.value, 100)
                    except Exception as e:
                        self.logger.debug(f"Ошибка загрузки свечей {symbol}: {e}")
                        reject_stats["no_data"] += 1; return None

                    if df is None or len(df) < 50:
                        return None

                    indicators = self.data_fetcher.calculate_indicators(df)
                    if not indicators:
                        return None

                    atr = indicators.get("atr_percent", 0)
                    adx = indicators.get("adx", 0)
                    if atr < self.current_min_atr:
                        reject_stats["atr"] += 1
                        return None
                    if adx < self.current_min_adx:
                        reject_stats["adx"] += 1
                        return None

                    multi_tf = {}
                    if self.use_multi_timeframe:
                        for tf in self.multi_tf_list:
                            try:
                                tf_df = await self.data_fetcher.fetch_klines_async(session, symbol, tf, 50)
                            except Exception:
                                continue
                            if tf_df is not None and len(tf_df) >= 30:
                                multi_tf[tf] = self.data_fetcher.calculate_indicators(tf_df)

                    from src.core.signals.signal_evaluator import SignalEvaluator
                    evaluator = SignalEvaluator(self.settings.data)
                    direction, strength, details = evaluator.evaluate(indicators, multi_tf)

                    if direction.value == "NEUTRAL" or strength < self.signal_quality_threshold:
                        if direction.value == "NEUTRAL":
                            reject_stats["neutral"] += 1
                        else:
                            reject_stats["weak_signal"] += 1
                        return None

                    if self.ml_predictor and self.settings.get("use_neural_predictor", False):
                        if not self.ml_predictor.should_enter(indicators):
                            self.logger.debug(f"{symbol}: rejected by ML filter")
                            reject_stats["ml"] += 1
                            return None

                    if self.settings.get("trap_detector_enabled", True):
                        ob = await self.data_fetcher.get_order_book(symbol)
                        is_trap, trap_reason = self.trap_detector.analyze_order_book(ob, direction.value)
                        if is_trap:
                            self.logger.info(f"Trap detected {symbol}: {trap_reason}")
                            reject_stats["trap"] += 1
                            return None

                    volume = symbol_volumes.get(symbol, 0)
                    rating = self.strategy_engine.calculate_rating(
                        symbol, volume, atr,
                        indicators.get("trend_score", 0),
                        indicators.get("rsi", 50),
                        0
                    )

                    return {
                        "symbol": symbol,
                        "direction": direction,
                        "strength": strength,
                        "rating": rating,
                        "indicators": {**indicators, **details, "entry_type": details.get("entry_type", "trend_following")},
                        "snapshot": {"lastPrice": indicators.get("close_price", 0)},
                        "multi_tf": multi_tf
                    }
                except Exception as e:
                    self.logger.debug(f"Error processing {symbol}: {e}")
                    return None

        tasks = [process_symbol(sym) for sym in filtered[:max_pairs]]
        results = await asyncio.gather(*tasks, return_exceptions=True)
        for res in results:
            if isinstance(res, dict):
                candidates.append(res)

        candidates.sort(key=lambda x: x["rating"], reverse=True)
        self.last_scan_results = candidates
        self.logger.info(f"Found {len(candidates)} candidates from {len(filtered)} pairs. Reject reasons: ATR={reject_stats['atr']}, ADX={reject_stats['adx']}, neutral={reject_stats['neutral']}, weak_signal={reject_stats['weak_signal']}, ML={reject_stats['ml']}, trap={reject_stats['trap']}, no_data={reject_stats['no_data']}")
        return candidates

    def train_ml_if_needed(self):
        if not self.ml_predictor:
            return
        try:
            from src.utils.sqlite_history import AsyncSQLiteTradeHistory
            import asyncio
            async def _train():
                db = AsyncSQLiteTradeHistory()
                trades = await db.get_trades(200)
                await db.close()
                if len(trades) >= self.min_trades_for_ml:
                    self.ml_predictor.train_if_needed(trades)
            asyncio.create_task(_train())
        except Exception as e:
            self.logger.debug(f"ML training error: {e}")
